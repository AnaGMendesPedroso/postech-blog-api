{
  "name": "postech-blog-api",
  "version": "1.0.0",
  "description": "API REST para professores publicarem conteúdo educacional para alunos",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:mutation": "stryker run",
    "lint": "eslint src/ tests/ --ext .js",
    "lint:fix": "eslint src/ tests/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "swagger:export": "node scripts/generate-swagger.js",
    "sonar": "sonar-scanner",
    "sonar:up": "./scripts/sonar-local.sh start",
    "sonar:down": "./scripts/sonar-local.sh stop",
    "sonar:reset": "./scripts/sonar-local.sh reset",
    "sonar:status": "./scripts/sonar-local.sh status",
    "sonar:analyze": "./scripts/sonar-local.sh analyze",
    "dev:setup": "./scripts/start-dev.sh",
    "dev:stop": "./scripts/start-dev.sh --stop",
    "dev:reset": "./scripts/start-dev.sh --reset",
    "dev:status": "./scripts/start-dev.sh --status",
    "docker:db": "docker compose -f docker-compose.dev.yml up -d",
    "docker:db:stop": "docker compose -f docker-compose.dev.yml down",
    "docker:db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "keywords": [
    "blog",
    "education",
    "nodejs",
    "express",
    "mongodb",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "joi": "^17.13.3",
    "mongoose": "^9.3.0",
    "sonarqube-scanner": "^4.3.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/jest-runner": "^8.7.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  }
}
